# -------------------------------------------------------
# ChatGPT Codex Connector – environment variable template
# -------------------------------------------------------
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: your OpenAI API key
OPENAI_API_KEY=sk-...

# -------------------------------------------------------
# Optional overrides (defaults shown)
# -------------------------------------------------------

# Model to use for code tasks
# Recommended options: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
CODEX_MODEL=gpt-4o

# Maximum number of tokens in each response
CODEX_MAX_TOKENS=2048

# Sampling temperature (0 = deterministic, 2 = very creative)
CODEX_TEMPERATURE=0.2

# HTTP request timeout in seconds
CODEX_TIMEOUT=60

# Number of times to retry a failed API request
CODEX_MAX_RETRIES=3

# Seconds to wait between retries (multiplied by attempt number)
CODEX_RETRY_DELAY=1.0

# Enable in-memory response cache (true/false)
CODEX_CACHE_ENABLED=false

# Cache entry time-to-live in seconds (used when cache is enabled)
CODEX_CACHE_TTL=3600

# Log level: DEBUG, INFO, WARNING, ERROR
CODEX_LOG_LEVEL=INFO
